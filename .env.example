# ============================================================
# Matchmaking Community MCP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o arquivo .env.
# NUNCA coloque IDs de projeto Supabase neste arquivo.
# ============================================================

# URL do projeto Supabase
# Encontre em: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=

# Anon key do projeto Supabase (chave pública — acesso restrito por RLS)
# Encontre em: Supabase Dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=

# Service role key — usada APENAS nos endpoints OAuth para escrever em mcp_community_sessions
# NUNCA exposta nas tools do MCP nem no client-side
# Encontre em: Supabase Dashboard → Settings → API → Project API keys → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# Porta local para desenvolvimento (padrão: 3000)
PORT=3000
